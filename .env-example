# Ambiente de execução: development | production | test
NODE_ENV=

# Senha do banco de dados
POSTGRES_PASSWORD=
# Usuário do banco de dados
POSTGRES_USER=
# Nome do banco de dados
POSTGRES_DB=

# Host do banco (ex: localhost)
DB_HOST=
# Porta do banco (padrão: 5432)
DB_PORT=
DB_USERNAME=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}
DB_DATABASE=${POSTGRES_DB}

# Rounds do bcrypt para hash de senhas (recomendado: 10)
SALT=

# Chave secreta para assinar tokens JWT
JWT_SECRET=
# Tempo de expiração do token (ex: 1d, 7d)
JWT_EXPIRATION=

# Tamanho máximo de upload de imagens (ex: 5242880 = 5mb)
IMAGE_SIZE=

# Região do bucket S3 (ex: sa-east-1)
S3_REGION=
# Nome do bucket S3
S3_BUCKET=
# URL da API do S3 (útil para MinIO/LocalStack)
S3_API_URL=
# URL pública dos arquivos
S3_WEB_URL=
# Access Key ID da credencial IAM
S3_KEY_ID=
# Secret Access Key da credencial IAM
S3_SECRET_KEY=
# true para MinIO/LocalStack, false para S3 padrão
S3_PATH_STYLE=

# Origens permitidas separadas por vírgula (ex: http://localhost:3000,https://meusite.com)
CORS_WHITELIST=

# Porta em que a aplicação irá rodar (ex: 3000)
PORT=
